PORT=3001
DB_PATH=./db/airbnb.db

# JWT Authentication (REQUIRED — change in production!)
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_EXPIRES_IN=7d

# OpenAI (for AI responses — optional)
OPENAI_API_KEY=

# Pricing defaults
BASE_PRICE=1500
WEEKEND_MULTIPLIER=1.3
CURRENCY=MXN

# Notification webhook (optional — for WhatsApp/Slack integration)
NOTIFICATION_WEBHOOK_URL=
